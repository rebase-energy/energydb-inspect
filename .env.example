# EnergyDB Inspect reads TIMEDB_PG_DSN / TIMEDB_CH_URL.
# By default the backend and notebook load `backend/libs/.env` (one dir up from energydb).
# These are the energydb local-db docker-compose defaults, shown here only for reference.
# LOCAL DATABASE ONLY — the backend refuses to connect if the host is not 127.0.0.1/localhost.
TIMEDB_PG_DSN=postgresql://postgres:devpassword@127.0.0.1:5433/devdb
TIMEDB_CH_URL=http://default:devpassword@localhost:8123/default
